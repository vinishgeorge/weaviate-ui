WEAVIATE_HOST=xxx
WEAVIATE_PORT=xxx
WEAVIATE_SECURE=
WEAVIATE_GRPC_HOST=xxx
WEAVIATE_GRPC_PORT=xxx
WEAVIATE_GRPC_SECURE=
WEAVIATE_USERNAME=xx
WEAVIATE_PASSWORD=xxxx
WEAVIATE_AUTH_CREDENTIALS=

# Azure AD (backend)
# Tenant ID of your Azure AD (or 'common' for multi-tenant during dev)
AZURE_AD_TENANT_ID=
# Client ID of your Azure App Registration (SPA or API)
AZURE_AD_CLIENT_ID=
# Optional: set audience if using a separate API App Registration
# e.g. api://<your-api-client-id> or the API app's client ID
AZURE_AD_AUDIENCE=
